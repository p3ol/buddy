{
  "name": "@poool/buddy",
  "version": "4.0.3",
  "description": "🐕 Dead simple cross-domain iframe messaging",
  "type": "module",
  "repository": "https://github.com/p3ol/buddy.git",
  "author": "Ugo Stephant <ugo@poool.fr>",
  "contributors": [
    "Nicolas Auger <nicolas@poool.fr>"
  ],
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/lib/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf ./dist || true",
    "build": "yarn clean && yarn build:code && yarn build:dts",
    "build:code": "tsdown",
    "build:dts": "tsc --project ./tsconfig.build.json",
    "test": "jest",
    "dev": "yarn dev:web & yarn dev:ws",
    "dev:web": "vite",
    "dev:ws": "yarn tsx --watch examples/websocket-server.ts",
    "prepack": "yarn lint && yarn build && yarn test",
    "lint": "eslint --max-warnings=0 --cache .",
    "release": "commit-and-tag-version && git push --follow-tags",
    "release:dry": "commit-and-tag-version --dry-run",
    "release:beta": "commit-and-tag-version --prerelease beta && git push --follow-tags",
    "release:rc": "commit-and-tag-version --prerelease rc && git push --follow-tags"
  },
  "devDependencies": {
    "@poool/eslint-config": "5.0.10",
    "@swc/core": "1.15.21",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/sinon": "21.0.1",
    "@types/ws": "8.18.1",
    "commit-and-tag-version": "12.7.1",
    "eslint": "9.39.4",
    "jest": "30.3.0",
    "jest-dev-server": "11.0.0",
    "puppeteer": "24.40.0",
    "sinon": "21.0.3",
    "ts-node": "10.9.2",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "ws": "8.20.0"
  },
  "targets": [
    "chrome109",
    "edge138",
    "firefox140",
    "safari18",
    "opera80",
    "node20"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "packageManager": "yarn@4.13.0"
}
